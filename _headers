# Cloudflare Pages - Custom Headers
# Pakeičia .htaccess cache taisykles

# Nuotraukos ir ikonos - 1 metai
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable

# Šriftai - 1 metai
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
/*.eot
  Cache-Control: public, max-age=31536000, immutable

# CSS - 1 diena (HTML visada naujas, tai CSS/JS versijuojami per URL parametrą)
/*.css
  Cache-Control: public, max-age=86400

# JS - 1 diena
/*.js
  Cache-Control: public, max-age=86400

# Atidaryti JS - visada naujas (kritinis saugumui)
/js/atidaryti.js
  Cache-Control: no-cache, must-revalidate

# HTML - visada revalidate (niekada sena cache)
/*.html
  Cache-Control: no-cache, must-revalidate

# Directory index puslapiai - visada revalidate
/
  Cache-Control: no-cache, must-revalidate
/sekimas/
  Cache-Control: no-cache, must-revalidate
/apie-mus/
  Cache-Control: no-cache, must-revalidate
/miltelinis-dazymas/
  Cache-Control: no-cache, must-revalidate
/dazai/
  Cache-Control: no-cache, must-revalidate
/kaina/
  Cache-Control: no-cache, must-revalidate
/kontaktai/
  Cache-Control: no-cache, must-revalidate
/galerija/
  Cache-Control: no-cache, must-revalidate
/atidaryti/
  Cache-Control: no-cache, must-revalidate
/darbuotojai/
  Cache-Control: no-cache, must-revalidate
/kontrole/
  Cache-Control: no-cache, must-revalidate

# Saugumo headeriai (visi puslapiai)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
